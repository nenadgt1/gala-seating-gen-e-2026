# Required in production
ADMIN_PASSWORD=replace-with-a-long-private-password
APP_SECRET=replace-with-a-long-random-secret

# Optional, makes the admin URL hidden. Example URL: /gala-private-7f39
ADMIN_PATH=gala-private-7f39

# Optional, leave empty if the moderator form should be open without a password
MODERATOR_PASSWORD=

# Recommended on Render with a persistent disk mounted at /data
DATA_FILE=/data/gala-data.json

# Keep * if embedding from WordPress or from several Gen-E domains
FRAME_ANCESTORS=*
